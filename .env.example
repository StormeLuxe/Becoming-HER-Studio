# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a NEW Supabase project for this app — do not share with Soft-Storme-After-Dark
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Create a NEW Stripe account or separate product set for this app
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Three studio plans — create each in Stripe Dashboard → Products
# Plan slugs: creator | pro | studio  (must match subscriptions.plan in DB)
STRIPE_CREATOR_PRICE_ID=price_creator_27   # Creator     $27/month  100 credits
STRIPE_PRO_PRICE_ID=price_pro_47           # Pro Creator $47/month  300 credits
STRIPE_STUDIO_PRICE_ID=price_studio_97     # Studio      $97/month  1000 credits

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
